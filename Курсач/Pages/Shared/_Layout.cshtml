<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Кадровая система</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Курсач.styles.css" asp-append-version="true" />
    <style>
        /* Стили для фиксированного уведомления */
        .fixed-alert-top {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            min-width: 300px;
            max-width: 500px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            border-radius: 8px;
            pointer-events: auto;
        }
    </style>
</head>
<body>
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        string navbarGradient = "linear-gradient(135deg, #667eea 0%, #764ba2 100%)"; // фиолетовый по умолчанию

        if (currentPage.StartsWith("/Departments"))
        {
            navbarGradient = "linear-gradient(135deg, #28a745 0%, #20c997 100%)"; // зеленый для отделов
        }
        else if (currentPage.StartsWith("/Positions"))
        {
            navbarGradient = "linear-gradient(135deg, #ffc107 0%, #fd7e14 100%)"; // рыжий для должностей
        }
        else if (currentPage.StartsWith("/EmployeeQualification"))
        {
            navbarGradient = "linear-gradient(135deg, #17a2b8 0%, #138496 100%)"; // бирюзовый для квалификации
        }
        else if (currentPage.StartsWith("/Admin/Users"))
        {
            navbarGradient = "linear-gradient(135deg, #dc3545 0%, #c82333 100%)"; // красный для пользователей
        }
        else if (currentPage.StartsWith("/Analytics"))
        {
            navbarGradient = "linear-gradient(135deg, #6f42c1 0%, #e83e8c 100%)"; // фиолетово-розовый для аналитики
        }
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-3" style="background: @navbarGradient; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-4" asp-page="/Index">
                    <i class="bi bi-building"></i> Кадровая система
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white @(currentPage == "/Index" ? "active fw-bold" : "")"
                               asp-page="/Index">
                                <i class="bi bi-house-door"></i> Главная
                            </a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white @(currentPage.StartsWith("/Employees") ? "active fw-bold" : "")"
                                   asp-page="/Employees/Index">
                                    <i class="bi bi-people"></i> Сотрудники
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white @(currentPage.StartsWith("/Admin/Users") ? "active fw-bold" : "")"
                                       asp-page="/Admin/Users">
                                        <i class="bi bi-people-fill"></i> Пользователи
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-white @(currentPage.StartsWith("/Departments") ? "active fw-bold" : "")"
                                   asp-page="/Departments/Index">
                                    <i class="bi bi-diagram-3"></i> Отделы
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white @(currentPage.StartsWith("/Positions") ? "active fw-bold" : "")"
                                   asp-page="/Positions/Index">
                                    <i class="bi bi-briefcase"></i> Должности
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white @(currentPage.StartsWith("/EmployeeQualification") ? "active fw-bold" : "")"
                                   asp-page="/EmployeeQualification">
                                    <i class="bi bi-calendar-check"></i> Квалификация и отпуск
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white @(currentPage.StartsWith("/Analytics") ? "active fw-bold" : "")"
                                   asp-page="/Analytics/Index">
                                    <i class="bi bi-graph-up"></i> Аналитика
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <span class="dropdown-item-text text-muted">
                                            <i class="bi bi-envelope"></i> @User.Identity.Name
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-page="/Auth/Logout" method="post" class="dropdown-item p-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right"></i> Выйти
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Auth/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Вход
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Функция показа уведомлений БЕЗ ПЕРЕМЕЩЕНИЯ СТРАНИЦЫ
        function showAlert(message, type) {
            var alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-' + type + ' alert-dismissible fade show fixed-alert-top text-center';
            alertDiv.setAttribute('role', 'alert');

            var icon = '';
            if (type === 'success') icon = 'check-circle-fill';
            else if (type === 'danger') icon = 'exclamation-triangle-fill';
            else icon = 'info-circle-fill';

            alertDiv.innerHTML = '<i class="bi bi-' + icon + '"></i> ' + message + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
            document.body.appendChild(alertDiv);

            // Сохраняем позицию скролла
            var scrollPosition = window.pageYOffset || document.documentElement.scrollTop;

            // Автоматическое скрытие через 3 секунды
            setTimeout(function () {
                alertDiv.style.opacity = '0';
                alertDiv.style.transition = 'opacity 0.3s';
                setTimeout(function () {
                    if (alertDiv.parentNode) alertDiv.remove();
                    // Восстанавливаем позицию скролла
                    window.scrollTo(0, scrollPosition);
                }, 300);
            }, 3000);
        }

        // Показываем уведомления из TempData
        @if (TempData["SuccessMessage"] != null)
        {
            <text>showAlert("@TempData["SuccessMessage"]", "success");</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>showAlert("@TempData["ErrorMessage"]", "danger");</text>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <text>showAlert("@TempData["InfoMessage"]", "info");</text>
        }
    </script>
</body>
</html>