@page
@using Курсач.Models
@model Курсач.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Управление пользователями";
    var isAdmin = User.IsInRole("Admin");
}

@if (!isAdmin)
{
    <div class="alert alert-danger text-center p-5 rounded-4">
        <i class="bi bi-shield-lock fs-1 d-block mb-3"></i>
        <h3>Доступ запрещен</h3>
        <p>У вас нет прав для просмотра этой страницы</p>
        <a asp-page="/Index" class="btn btn-primary rounded-3">Вернуться на главную</a>
    </div>
    return;
}

<div class="container-fluid px-4">
    <div class="hero-section text-center py-4 mb-4" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); border-radius: 0 0 2rem 2rem; margin-top: -1.5rem;">
        <div class="container">
            <h1 class="display-5 fw-bold text-white mb-2">
                <i class="bi bi-people-fill"></i> Управление пользователями
            </h1>
            <p class="lead text-white mb-0">
                Создание, редактирование и управление учетными записями пользователей
            </p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Форма создания пользователя -->
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-header text-white rounded-top-4 p-3" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); border-bottom: none;">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Создать нового пользователя</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="CreateUser">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Логин (UserName):</label>
                            <input type="text" name="userName" class="form-control rounded-3" placeholder="Введите логин" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email:</label>
                            <input type="email" name="email" class="form-control rounded-3" placeholder="user@example.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Пароль:</label>
                            <input type="password" name="password" class="form-control rounded-3" placeholder="Введите пароль" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Подтверждение пароля:</label>
                            <input type="password" name="confirmPassword" class="form-control rounded-3" placeholder="Повторите пароль" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">ФИО:</label>
                            <input type="text" name="fullName" class="form-control rounded-3" placeholder="Введите ФИО" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Роль:</label>
                            <select name="role" class="form-select rounded-3">
                                <option value="User">Пользователь (User)</option>
                                <option value="Admin">Администратор (Admin)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success w-100 rounded-3 py-2">
                            <i class="bi bi-plus-circle"></i> Создать пользователя
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Список пользователей -->
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4 h-100">
                <div class="card-header text-white rounded-top-4 p-3" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%); border-bottom: none;">
                    <h4 class="mb-0"><i class="bi bi-list-check"></i> Список пользователей</h4>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0 w-100">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3" style="width: 15%;">Логин</th>
                                <th class="p-3" style="width: 25%;">Email</th>
                                <th class="p-3" style="width: 35%;">ФИО</th>
                                <th class="p-3" style="width: 10%;">Роль</th>
                                <th class="p-3 text-center" style="width: 15%;">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td class="p-3"><strong>@user.UserName</strong></td>
                                    <td class="p-3" style="white-space: nowrap;">@user.Email</td>
                                    <td class="p-3">@(string.IsNullOrEmpty(user.FullName) ? "—" : user.FullName)</td>
                                    <td class="p-3">
                                        @{
                                            var role = Model.UserRoles.ContainsKey(user.Id) ? Model.UserRoles[user.Id] : "User";
                                            string badgeClass = role == "Admin" ? "bg-danger" : "bg-primary";
                                        }
                                        <span class="badge @badgeClass rounded-pill px-3 py-2">@role</span>
                                    </td>
                                    <td class="p-3 text-center">
                                        <div class="d-flex flex-column gap-2 justify-content-center">
                                            <button type="button" class="btn btn-sm btn-warning rounded-3"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editUserModal"
                                                    data-id="@user.Id"
                                                    data-username="@user.UserName"
                                                    data-email="@user.Email"
                                                    data-fullname="@user.FullName"
                                                    data-role="@role">
                                                <i class="bi bi-pencil"></i> Изменить
                                            </button>
                                            <a asp-page-handler="DeleteUser" asp-route-userId="@user.Id"
                                               class="btn btn-sm btn-danger rounded-3"
                                               onclick="return confirm('Удалить пользователя @user.UserName?')">
                                                <i class="bi bi-trash"></i> Удалить
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно редактирования пользователя -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <div class="modal-header" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
                <h5 class="modal-title text-white"><i class="bi bi-pencil-square"></i> Редактировать пользователя</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="EditUser">
                <div class="modal-body">
                    <input type="hidden" name="userId" id="editUserId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Логин:</label>
                        <input type="text" name="userName" id="editUserName" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email:</label>
                        <input type="email" name="email" id="editEmail" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">ФИО:</label>
                        <input type="text" name="fullName" id="editFullName" class="form-control rounded-3" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Роль:</label>
                        <select name="role" id="editRole" class="form-select rounded-3">
                            <option value="User">Пользователь (User)</option>
                            <option value="Admin">Администратор (Admin)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Новый пароль (оставьте пустым, чтобы не менять):</label>
                        <input type="password" name="newPassword" class="form-control rounded-3" placeholder="Введите новый пароль" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4">Сохранить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .hero-section {
        border-radius: 0 0 2rem 2rem;
        margin-top: -1.5rem;
    }

    .btn {
        transition: all 0.2s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .card {
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .rounded-top-4 {
        border-top-left-radius: 1rem !important;
        border-top-right-radius: 1rem !important;
    }

    .rounded-3 {
        border-radius: 0.75rem !important;
    }

    .table th, .table td {
        vertical-align: middle;
    }

    /* Email в одну строку */
    .table td {
        white-space: normal;
    }

        .table td:nth-child(2) {
            white-space: nowrap;
        }

    /* Кнопки в столбик */
    .d-flex.flex-column {
        gap: 6px !important;
    }

    .btn-sm {
        min-width: 100px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }
</style>

<script>
    // Заполнение модального окна данными пользователя
    const editUserModal = document.getElementById('editUserModal');
    if (editUserModal) {
        editUserModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const userId = button.getAttribute('data-id');
            const userName = button.getAttribute('data-username');
            const email = button.getAttribute('data-email');
            const fullName = button.getAttribute('data-fullname');
            const role = button.getAttribute('data-role');

            document.getElementById('editUserId').value = userId;
            document.getElementById('editUserName').value = userName;
            document.getElementById('editEmail').value = email;
            document.getElementById('editFullName').value = fullName || '';
            document.getElementById('editRole').value = role;
        });
    }
</script>