@page
@model Курсач.Pages.Departments.EditModel
@{
    ViewData["Title"] = "Редактировать отдел";
}

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow mb-4">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Редактировать отдел
                    </h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-route-id="@Model.Department.Id">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Department.Name" class="form-label fw-bold"></label>
                            <input asp-for="Department.Name" class="form-control" />
                            <span asp-validation-for="Department.Name" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-page="./Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Назад
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Сохранить название
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-people"></i> Сотрудники отдела (@Model.Employees.Count)
                    </h4>
                </div>
                <div class="card-body">
                    @if (!Model.Employees.Any())
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> В этом отделе пока нет сотрудников.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>ФИО</th>
                                        <th>Должность</th>
                                        <th>Email</th>
                                        <th>Действие</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var employee in Model.Employees)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@employee.FullName</strong>
                                            </td>
                                            <td>@employee.Position</td>
                                            <td>
                                                <a href="mailto:@employee.Email" class="text-decoration-none">
                                                    <i class="bi bi-envelope"></i> @employee.Email
                                                </a>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#moveEmployeeModal"
                                                        data-employee-id="@employee.Id"
                                                        data-employee-name="@employee.FullName">
                                                    <i class="bi bi-arrow-right-circle"></i> Переместить
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для перемещения сотрудника -->
<div class="modal fade" id="moveEmployeeModal" tabindex="-1" aria-labelledby="moveEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="moveEmployeeModalLabel">
                    <i class="bi bi-arrow-left-right"></i> Перемещение сотрудника
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="MoveEmployee" asp-route-id="@Model.Department.Id">
                <div class="modal-body">
                    <input type="hidden" id="selectedEmployeeId" name="SelectedEmployeeId" />
                    <p>Выберите отдел для перемещения сотрудника:</p>
                    <div class="alert alert-info">
                        <strong id="employeeName"></strong>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Отдел назначения:</label>
                        <select asp-for="TargetDepartmentId" asp-items="Model.OtherDepartments"
                                class="form-control" required>
                            <option value="">-- Выберите отдел --</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Переместить
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Передаем данные сотрудника в модальное окно
        const moveEmployeeModal = document.getElementById('moveEmployeeModal');
        if (moveEmployeeModal) {
            moveEmployeeModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const employeeId = button.getAttribute('data-employee-id');
                const employeeName = button.getAttribute('data-employee-name');

                const modalTitle = moveEmployeeModal.querySelector('#employeeName');
                const selectedEmployeeId = moveEmployeeModal.querySelector('#selectedEmployeeId');

                modalTitle.textContent = employeeName;
                selectedEmployeeId.value = employeeId;
            });
        }
    </script>
}