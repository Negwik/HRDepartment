@page
@using Курсач.Models
@model Курсач.Pages.EmployeeQualificationModel
@{
    ViewData["Title"] = "Квалификация и отпуск";
    var isAdmin = User.IsInRole("Admin");
}

<style>
    .fixed-alert {
        position: fixed;
        top: 70px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        min-width: 300px;
        max-width: 500px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .hero-section {
        border-radius: 0 0 2rem 2rem;
        margin-top: -1.5rem;
    }

    .card {
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .card-header {
        border-bottom: none;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .rounded-top-4 {
        border-top-left-radius: 1rem !important;
        border-top-right-radius: 1rem !important;
    }

    .btn {
        transition: all 0.2s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .card:hover {
        transform: translateY(-3px);
    }

    .table th, .table td {
        vertical-align: middle;
    }

    select.form-select {
        cursor: pointer;
    }

    #employeeSelect option {
        padding: 8px 12px;
    }

    .modal-content {
        animation: modalSlideIn 0.3s ease-out;
    }

    @@keyframes modalSlideIn {
        from {
            transform: translateY(-50px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show fixed-alert text-center" role="alert" id="successAlert">
        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show fixed-alert text-center" role="alert" id="errorAlert">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid px-4">
    <div class="hero-section text-center py-4 mb-4" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
        <div class="container">
            <h1 class="display-5 fw-bold text-white mb-2">
                <i class="bi bi-calendar-check"></i> Квалификация и отпуск
            </h1>
            <p class="lead text-white mb-0">
                Управление отпусками и повышением квалификации сотрудников
            </p>
        </div>
    </div>

    <!-- Выбор сотрудника с поиском -->
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <label class="form-label fw-bold mb-2">
                        <i class="bi bi-search"></i> Поиск сотрудника:
                    </label>
                    <input type="text" id="searchEmployee" class="form-control mb-3 rounded-3" placeholder="Введите фамилию, имя или email..." />
                    <select id="employeeSelect" class="form-select rounded-3" style="min-height: 200px;" size="5" onchange="location.href='?employeeId=' + this.value">
                        <option value="">-- Выберите сотрудника --</option>
                        @if (Model.EmployeesList != null)
                        {
                            @foreach (var emp in Model.EmployeesList)
                            {
                                <option value="@emp.Id" selected="@(Model.SelectedEmployeeId == emp.Id)" data-name="@emp.LastName @emp.FirstName @emp.MiddleName @emp.Email">
                                    @emp.LastName @emp.FirstName @emp.MiddleName - @emp.Department?.Name
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (Model.SelectedEmployee != null)
    {
        <!-- Информация о выбранном сотруднике -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-circle fs-2 text-white me-3"></i>
                            <div>
                                <h5 class="text-white mb-0 fw-bold">@Model.SelectedEmployee.LastName @Model.SelectedEmployee.FirstName @Model.SelectedEmployee.MiddleName</h5>
                                <small class="text-white opacity-75">@Model.SelectedEmployee.Department?.Name • @Model.SelectedEmployee.Position?.Title</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Блок отпуска -->
            <div class="col-md-6">
                <div class="card shadow-lg border-0 rounded-4 h-100">
                    <div class="card-header text-white rounded-top-4 p-3" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%); border-bottom: none;">
                        <h4 class="mb-0"><i class="bi bi-sun"></i> Отпуск</h4>
                    </div>
                    <div class="card-body p-4">
                        @if (Model.SelectedEmployee.VacationStartDate.HasValue && Model.SelectedEmployee.VacationEndDate.HasValue)
                        {
                            var today = DateTime.Today;
                            var isOnVacation = today >= Model.SelectedEmployee.VacationStartDate.Value && today <= Model.SelectedEmployee.VacationEndDate.Value;

                            <div class="alert @(isOnVacation ? "alert-warning" : "alert-info") text-center rounded-3">
                                @if (isOnVacation)
                                {
                                    <i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>
                                    <strong>Сотрудник в отпуске!</strong>

                                    <br />
                                }
                                <span>Тип: <strong>@GetDisplayName(Model.SelectedEmployee.VacationType)</strong></span><br />
                                <span>с <strong>@Model.SelectedEmployee.VacationStartDate.Value.ToString("dd.MM.yyyy")</strong></span><br />
                                <span>по <strong>@Model.SelectedEmployee.VacationEndDate.Value.ToString("dd.MM.yyyy")</strong></span>
                                @{
                                    var start = Model.SelectedEmployee.VacationStartDate.Value;
                                    var end = Model.SelectedEmployee.VacationEndDate.Value;
                                    var days = (end - start).Days + 1;
                                }
                                <br /><span class="text-muted">Длительность: @days дн.</span>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary text-center rounded-3">
                                <i class="bi bi-calendar fs-3 d-block mb-2"></i>
                                <strong>Нет запланированного отпуска</strong>
                            </div>
                        }

                        @if (isAdmin)
                        {
                            <form method="post" asp-page-handler="UpdateVacation" class="mt-3" id="vacationForm">
                                <input type="hidden" name="employeeId" value="@Model.SelectedEmployee.Id" />
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Тип отпуска:</label>
                                    <select name="vacationType" class="form-select rounded-3">
                                        @foreach (VacationType type in Enum.GetValues(typeof(VacationType)))
                                        {
                                            <option value="@((int)type)" selected="@(Model.SelectedEmployee.VacationType == type)">
                                                @GetDisplayName(type)
                                            </option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Начало отпуска:</label>
                                    <input type="date" name="startDate" class="form-control rounded-3" value="@(Model.SelectedEmployee.VacationStartDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Конец отпуска:</label>
                                    <input type="date" name="endDate" class="form-control rounded-3" value="@(Model.SelectedEmployee.VacationEndDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary flex-fill rounded-3">
                                        <i class="bi bi-save"></i> Сохранить
                                    </button>
                                    <button type="button" class="btn btn-danger rounded-3" data-bs-toggle="modal" data-bs-target="#clearVacationModal">
                                        <i class="bi bi-trash"></i> Очистить
                                    </button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- Блок квалификации -->
            <div class="col-md-6">
                <div class="card shadow-lg border-0 rounded-4 h-100">
                    <div class="card-header text-white rounded-top-4 p-3" style="background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%); border-bottom: none;">
                        <h4 class="mb-0"><i class="bi bi-mortarboard"></i> Повышение квалификации</h4>
                    </div>
                    <div class="card-body p-4">
                        @if (Model.SelectedEmployee.Qualifications != null && Model.SelectedEmployee.Qualifications.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="p-2">Курс</th>
                                            <th class="p-2">Даты</th>
                                            <th class="p-2">Организация</th>
                                            <th class="p-2">Статус</th>
                                            <th class="p-2 text-center">Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var q in Model.SelectedEmployee.Qualifications)
                                        {
                                            <tr>
                                                <td class="p-2"><strong>@q.CourseName</strong></td>
                                                <td class="p-2">@q.StartDate.ToString("dd.MM.yyyy")<br />—<br />@q.EndDate.ToString("dd.MM.yyyy")</td>
                                                <td class="p-2">@(string.IsNullOrEmpty(q.Organization) ? "—" : q.Organization)</td>
                                                <td class="p-2">
                                                    @{
                                                        string badgeClass = "bg-secondary";
                                                        string statusText = "Запланирован";
                                                        if (q.Status == QualificationStatus.InProgress)
                                                        {
                                                            badgeClass = "bg-primary";
                                                            statusText = "В процессе";
                                                        }
                                                        else if (q.Status == QualificationStatus.Completed)
                                                        {
                                                            badgeClass = "bg-success";
                                                            statusText = "Завершен";
                                                        }
                                                        else if (q.Status == QualificationStatus.Cancelled)
                                                        {
                                                            badgeClass = "bg-danger";
                                                            statusText = "Отменен";
                                                        }
                                                    }
                                                    <span class="badge @badgeClass rounded-pill px-3 py-2">@statusText</span>
                                                </td>
                                                <td class="p-2 text-center">
                                                    @if (isAdmin)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-warning rounded-3" onclick="openEditModal(@q.Id, '@q.CourseName.Replace("'", "\\'")', '@q.StartDate.ToString("yyyy-MM-dd")', '@q.EndDate.ToString("yyyy-MM-dd")', '@(q.Organization?.Replace("'", "\\'") ?? "")', @((int)q.Status))">
                                                            <i class="bi bi-pencil"></i> Изменить
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-danger rounded-3 mt-1" data-bs-toggle="modal" data-bs-target="#deleteQualificationModal" data-id="@q.Id" data-name="@q.CourseName">
                                                            <i class="bi bi-trash"></i> Удалить
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary text-center rounded-3">
                                <i class="bi bi-book fs-3 d-block mb-2"></i>
                                <strong>Нет записей о повышении квалификации</strong>
                            </div>
                        }

                        @if (isAdmin)
                        {
                            <hr class="my-4" />
                            <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle"></i> Добавить курс</h6>
                            <form method="post" asp-page-handler="AddQualification">
                                <input type="hidden" name="employeeId" value="@Model.SelectedEmployee.Id" />
                                <div class="mb-2">
                                    <input type="text" name="courseName" class="form-control rounded-3" placeholder="Название курса" required />
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <input type="date" name="startDate" class="form-control rounded-3" required />
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="date" name="endDate" class="form-control rounded-3" required />
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <input type="text" name="organization" class="form-control rounded-3" placeholder="Организация (опционально)" />
                                </div>
                                <div class="mb-3">
                                    <select name="status" class="form-select rounded-3">
                                        <option value="0">Запланирован</option>
                                        <option value="1">В процессе</option>
                                        <option value="2">Завершен</option>
                                        <option value="3">Отменен</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-success w-100 rounded-3">
                                    <i class="bi bi-plus"></i> Добавить курс
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center p-5 rounded-4">
            <i class="bi bi-person fs-1 d-block mb-3"></i>
            <h4>Выберите сотрудника</h4>
            <p>Для управления отпусками и квалификацией выберите сотрудника из списка выше</p>
        </div>
    }
</div>

<!-- Модальное окно для очистки отпуска -->
<div class="modal fade" id="clearVacationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-white bg-opacity-25 p-2">
                        <i class="bi bi-exclamation-triangle-fill text-white fs-4"></i>
                    </div>
                    <h5 class="modal-title text-white fw-bold">Подтверждение действия</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <i class="bi bi-calendar-x fs-1 text-danger mb-3 d-block"></i>
                <h5 class="fw-bold mb-2">Очистка дат отпуска</h5>
                <p class="text-muted mb-0">Вы уверены, что хотите очистить даты отпуска?</p>
                <p class="text-danger small mt-2">Это действие нельзя отменить.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i> Отмена
                </button>
                <a asp-page-handler="ClearVacation" asp-route-employeeId="@Model.SelectedEmployee?.Id" class="btn btn-danger rounded-3 px-4" id="clearVacationLink">
                    <i class="bi bi-trash"></i> Очистить
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для удаления курса -->
<div class="modal fade" id="deleteQualificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-white bg-opacity-25 p-2">
                        <i class="bi bi-exclamation-triangle-fill text-white fs-4"></i>
                    </div>
                    <h5 class="modal-title text-white fw-bold">Подтверждение удаления</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <i class="bi bi-bookmark-x fs-1 text-danger mb-3 d-block"></i>
                <h5 class="fw-bold mb-2">Удаление курса</h5>
                <p class="text-muted mb-0">Вы уверены, что хотите удалить курс:</p>
                <p class="fw-bold text-danger mt-2" id="deleteCourseName"></p>
                <p class="text-danger small mt-2">Это действие нельзя отменить.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i> Отмена
                </button>
                <a id="deleteCourseLink" class="btn btn-danger rounded-3 px-4">
                    <i class="bi bi-trash"></i> Удалить
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно для редактирования курса -->
<div class="modal fade" id="editQualificationModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0" style="background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-white bg-opacity-25 p-2">
                        <i class="bi bi-pencil-square text-white fs-4"></i>
                    </div>
                    <h5 class="modal-title text-white fw-bold">Редактировать курс</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="EditQualification">
                <div class="modal-body p-4">
                    <input type="hidden" name="qId" id="editQId" />
                    <input type="hidden" name="employeeId" value="@Model.SelectedEmployee?.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Название курса:</label>
                        <input type="text" name="courseName" id="editCourseName" class="form-control rounded-3" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Дата начала:</label>
                            <input type="date" name="startDate" id="editStartDate" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Дата окончания:</label>
                            <input type="date" name="endDate" id="editEndDate" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Организация:</label>
                        <input type="text" name="organization" id="editOrganization" class="form-control rounded-3" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Статус:</label>
                        <select name="status" id="editStatus" class="form-select rounded-3">
                            <option value="0">Запланирован</option>
                            <option value="1">В процессе</option>
                            <option value="2">Завершен</option>
                            <option value="3">Отменен</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 justify-content-center gap-3 pb-4">
                    <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i> Отмена
                    </button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4">
                        <i class="bi bi-save"></i> Сохранить
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    public static string GetDisplayName(Enum value)
    {
        var field = value.GetType().GetField(value.ToString());
        var attribute = field?.GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false).FirstOrDefault() as System.ComponentModel.DataAnnotations.DisplayAttribute;
        return attribute?.Name ?? value.ToString();
    }
}

<script>
    // Сохраняем позицию скролла перед отправкой формы
    var scrollPosition = 0;

    // Функция для сохранения позиции скролла
    function saveScrollPosition() {
        scrollPosition = window.pageYOffset || document.documentElement.scrollTop;
    }

    // Функция для восстановления позиции скролла
    function restoreScrollPosition() {
        setTimeout(function () {
            window.scrollTo(0, scrollPosition);
        }, 100);
    }

    // Сохраняем позицию перед отправкой формы отпуска
    var vacationForm = document.getElementById('vacationForm');
    if (vacationForm) {
        vacationForm.addEventListener('submit', function () {
            saveScrollPosition();
        });
    }

    // Сохраняем позицию перед кликом по ссылке очистки
    var clearVacationLink = document.getElementById('clearVacationLink');
    if (clearVacationLink) {
        clearVacationLink.addEventListener('click', function () {
            saveScrollPosition();
        });
    }

    // Восстанавливаем позицию после загрузки страницы
    window.addEventListener('load', function () {
        restoreScrollPosition();
    });

    // Поиск сотрудника в выпадающем списке
    document.getElementById('searchEmployee')?.addEventListener('keyup', function () {
        var searchText = this.value.toLowerCase();
        var options = document.querySelectorAll('#employeeSelect option');

        for (var i = 0; i < options.length; i++) {
            if (options[i].value === "") continue;
            var text = options[i].getAttribute('data-name')?.toLowerCase() || options[i].textContent.toLowerCase();
            if (text.indexOf(searchText) !== -1) {
                options[i].style.display = '';
            } else {
                options[i].style.display = 'none';
            }
        }
    });

    // Открытие модального окна редактирования курса
    function openEditModal(id, courseName, startDate, endDate, organization, status) {
        document.getElementById('editQId').value = id;
        document.getElementById('editCourseName').value = courseName;
        document.getElementById('editStartDate').value = startDate;
        document.getElementById('editEndDate').value = endDate;
        document.getElementById('editOrganization').value = organization;
        document.getElementById('editStatus').value = status;

        var modal = new bootstrap.Modal(document.getElementById('editQualificationModal'));
        modal.show();
    }

    // Удаление курса с подтверждением
    var deleteModal = document.getElementById('deleteQualificationModal');
    if (deleteModal) {
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var courseId = button.getAttribute('data-id');
            var courseName = button.getAttribute('data-name');

            var deleteLink = document.getElementById('deleteCourseLink');
            var courseNameSpan = document.getElementById('deleteCourseName');

            courseNameSpan.textContent = courseName;
            deleteLink.href = '?handler=DeleteQualification&qId=' + courseId + '&employeeId=' + @(Model.SelectedEmployee?.Id ?? 0);

            // Сохраняем позицию перед удалением
            saveScrollPosition();
        });
    }

    // Сохраняем позицию перед отправкой формы добавления курса
    var addCourseForms = document.querySelectorAll('form[asp-page-handler="AddQualification"]');
    for (var i = 0; i < addCourseForms.length; i++) {
        addCourseForms[i].addEventListener('submit', function () {
            saveScrollPosition();
        });
    }

    // Сохраняем позицию перед отправкой формы редактирования курса
    var editForm = document.getElementById('editForm');
    if (editForm) {
        editForm.addEventListener('submit', function () {
            saveScrollPosition();
        });
    }

    // Автоматическое скрытие уведомлений с восстановлением позиции
    setTimeout(function () {
        var alerts = document.querySelectorAll('.fixed-alert');
        for (var i = 0; i < alerts.length; i++) {
            alerts[i].style.opacity = '0';
            alerts[i].style.transition = 'opacity 0.3s';
            setTimeout(function (alert) {
                if (alert && alert.parentNode) alert.remove();
                restoreScrollPosition();
            }, 300, alerts[i]);
        }
    }, 3000);
</script>