@page
@model Курсач.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Сотрудники";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid px-4">
    <div class="hero-section text-center py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 0 0 2rem 2rem; margin-top: -1.5rem;">
        <div class="container">
            <h1 class="display-4 fw-bold text-white mb-3">
                <i class="bi bi-people-fill"></i> Сотрудники компании
            </h1>
            <p class="lead text-white fs-5 mb-0">
                Управление кадровым составом организации
            </p>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-person-badge"></i> Список сотрудников
            </h2>
            <p class="text-muted">Всего сотрудников: <strong class="text-primary fs-5">@Model.Employees.Count</strong></p>
        </div>
        <div class="d-flex gap-2">
            <div class="input-group" style="width: 280px;">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Поиск по ФИО, email, отделу...">
            </div>
            @if (isAdmin)
            {
                <a asp-page="Create" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-plus-circle"></i> Добавить сотрудника
                </a>
            }
        </div>
    </div>

    @if (!Model.Employees.Any())
    {
        <div class="alert alert-info text-center p-5">
            <i class="bi bi-info-circle fs-1"></i>
            <h4>Нет сотрудников</h4>
            <p>Нажмите "Добавить сотрудника" чтобы создать первую запись</p>
        </div>
    }
    else
    {
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0 w-100" id="employeesTable">
                        <thead style="background-color: #212529; color: white;">
                            <tr>
                                <th class="py-3 px-2">ФИО</th>
                                <th class="py-3 px-2">Отдел</th>
                                <th class="py-3 px-2">Должность</th>
                                <th class="py-3 px-2">Email</th>
                                <th class="py-3 px-2">Телефон</th>
                                <th class="py-3 px-2">Дата приема</th>
                                <th class="py-3 px-2">Зарплата</th>
                                <th class="py-3 px-2 text-center">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model.Employees)
                            {
                                var hireDate = employee.HireDate;
                                var today = DateTime.Today;
                                var years = today.Year - hireDate.Year;
                                var months = today.Month - hireDate.Month;
                                if (months < 0) { years--; months += 12; }
                                var experienceText = years > 0 ? $"{years} г. {months} мес." : $"{months} мес.";

                                <tr>
                                    <td class="px-2 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2 flex-shrink-0">
                                                <i class="bi bi-person-circle text-primary fs-5"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@employee.LastName @employee.FirstName</div>
                                                @if (!string.IsNullOrEmpty(employee.MiddleName))
                                                {
                                                    <div class="small text-muted">@employee.MiddleName</div>
                                                }
                                                <small class="text-muted">ID: @employee.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-2 py-3">
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1 rounded-pill">
                                            <i class="bi bi-building"></i> @(employee.Department?.Name ?? "Не указан")
                                        </span>
                                    </td>
                                    <td class="px-2 py-3">
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill">
                                            <i class="bi bi-briefcase"></i> @(employee.Position?.Title ?? "Не указана")
                                        </span>
                                    </td>
                                    <td class="px-2 py-3">
                                        <a href="mailto:@employee.Email" class="text-decoration-none">
                                            <i class="bi bi-envelope"></i> @employee.Email
                                        </a>
                                    </td>
                                    <td class="px-2 py-3">
                                        @if (!string.IsNullOrEmpty(employee.PhoneNumber))
                                        {
                                            <a href="tel:@employee.PhoneNumber" class="text-decoration-none">
                                                <i class="bi bi-telephone"></i> @employee.PhoneNumber
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="px-2 py-3">
                                        <i class="bi bi-calendar3"></i>
                                        @employee.HireDate.ToString("dd.MM.yyyy")
                                        <br />
                                        <small class="text-muted">@experienceText</small>
                                    </td>
                                    <td class="px-2 py-3">
                                        <span class="fw-bold text-success">
                                            @employee.Salary.ToString("N0") ₽
                                        </span>
                                    </td>
                                    <td class="px-2 py-3 text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-page="Details" asp-route-id="@employee.Id"
                                               class="btn btn-outline-info" title="Просмотр">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (isAdmin)
                                            {
                                                <a asp-page="Edit" asp-route-id="@employee.Id"
                                                   class="btn btn-outline-warning" title="Редактировать">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-page="Delete" asp-route-id="@employee.Id"
                                                   class="btn btn-outline-danger" title="Удалить">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 0 0 2rem 2rem;
        margin-top: -1.5rem;
    }

    /* Убираем любые трансформации у всей таблицы и ее контейнера */
    .table-responsive,
    .card,
    .card-body,
    .table,
    .table tbody,
    .table tr,
    .table td,
    .table th {
        transform: none !important;
        transition: none !important;
    }

        /* Строки меняют цвет при наведении - более темный серый */
        .table tbody tr:hover {
            background-color: #e0e0e0 !important;
            transition: background-color 0.2s ease;
        }

    /* Кнопки двигаются при наведении */
    .btn {
        transition: transform 0.2s ease, background-color 0.2s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    /* Кнопки в группе */
    .btn-group .btn {
        transition: transform 0.2s ease, background-color 0.2s ease;
    }

        .btn-group .btn:hover {
            transform: translateY(-2px);
        }

    /* Ссылки-кнопки */
    a.btn {
        transition: transform 0.2s ease, background-color 0.2s ease;
    }

        a.btn:hover {
            transform: translateY(-2px);
        }

    /* Кнопки в карточках */
    .btn-outline-info, .btn-outline-warning, .btn-outline-danger {
        transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
    }

        .btn-outline-info:hover {
            background: #0dcaf0;
            border-color: #0dcaf0;
            color: white;
        }

        .btn-outline-warning:hover {
            background: #ffc107;
            border-color: #ffc107;
            color: white;
        }

        .btn-outline-danger:hover {
            background: #dc3545;
            border-color: #dc3545;
            color: white;
        }

    .badge {
        font-weight: 500;
        font-size: 0.8rem;
    }

    .avatar-circle {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(102, 126, 234, 0.1);
        border-radius: 50%;
    }

        .avatar-circle i {
            font-size: 1rem;
        }

    .input-group {
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        border-radius: 10px;
        overflow: hidden;
    }

        .input-group .form-control:focus {
            box-shadow: none;
            border-color: #667eea;
        }

    .table td {
        vertical-align: middle;
        font-size: 0.85rem;
    }

    .table thead th {
        background-color: #212529;
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

<script>
    document.getElementById('searchInput')?.addEventListener('keyup', function () {
        var searchText = this.value.toLowerCase();
        var rows = document.querySelectorAll('.employee-row');

        for (var i = 0; i < rows.length; i++) {
            var text = rows[i].textContent.toLowerCase();
            if (text.indexOf(searchText) !== -1) {
                rows[i].style.display = '';
            } else {
                rows[i].style.display = 'none';
            }
        }
    });
</script>